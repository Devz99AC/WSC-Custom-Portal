<?xml version="1.0" encoding="UTF-8"?>
<ConnectedApp xmlns="http://soap.sforce.com/2006/04/metadata">
    <contactEmail>support@wholesaleshelfcorporations.com</contactEmail>
    <label>WSC Portal BFF</label>
    <description>Server-to-server integration for the WSC Customer Portal BFF (OAuth 2.0 JWT Bearer, ROADMAP 1.4/1.6). The certificate below is PUBLIC and safe to version. The matching PRIVATE key never lives in git - it is held only in the secrets manager as SF_JWT_PRIVATE_KEY.</description>
    <oauthConfig>
        <callbackUrl>http://localhost:1717/OauthRedirect</callbackUrl>
        <certificate></certificate>
        <isAdminApproved>true</isAdminApproved>
        <scopes>Api</scopes>
        <scopes>RefreshToken</scopes>
    </oauthConfig>
    <!-- "Permitted Users = Admin approved users are pre-authorized" is expressed by
         oauthConfig/isAdminApproved above; ConnectedAppOauthPolicy has no permittedUsers. -->
    <oauthPolicy>
        <ipRelaxation>BYPASS</ipRelaxation>
    </oauthPolicy>
</ConnectedApp>
