{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://wscbff-production.up.railway.app/api/:path*" },
    { "source": "/auth/:path*", "destination": "https://wscbff-production.up.railway.app/auth/:path*" },
    { "source": "/((?!api|auth|assets|prototype.html).*)", "destination": "/index.html" }
  ]
}
