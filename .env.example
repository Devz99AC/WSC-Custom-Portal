# =============================================================================
# WSC Customer Portal — environment variable inventory (NAMES ONLY)
# =============================================================================
# Copy to `.env.local` (git-ignored) for local dev and fill from your secrets
# manager (AWS Secrets Manager / Azure Key Vault / Doppler). NEVER commit real
# values (CLAUDE.md §4). Lines marked `# secret` MUST come from the manager and
# must never reach the browser (only STRIPE_PUBLISHABLE_KEY is client-safe).
#
# Canonical source: docs/ARCHITECTURE.md §5.1 (superset). ROADMAP Appendix C is a
# shorter subset; where its names differ, the mapping is noted inline. Phase 0
# boots on the operational vars only — integration secrets are consumed starting
# in Phase 1, so leaving them blank locally is fine for now.
# -----------------------------------------------------------------------------

# --- BFF runtime (operational; required to boot) -----------------------------
NODE_ENV=development
PORT=8080
HOST=0.0.0.0
LOG_LEVEL=info

# --- Demo data source ---------------------------------------------------------
# "mock" = in-memory real-shaped data (default). "salesforce" = live reads reusing the
# Salesforce CLI's `sf org login` session (dev-only, one developer machine, NO Connected
# App/JWT needed). "salesforce-jwt" = live reads via the REAL JWT Bearer flow below —
# works from any host (this is what a deployed/public demo or production must use).
PORTAL_DATA_SOURCE=mock
SF_TARGET_USERNAME=            # e.g. sf_admin@utopia6.com.devinzonde (from `sf org list`) — "salesforce" mode only

# --- Salesforce (OAuth 2.0 JWT Bearer — required for PORTAL_DATA_SOURCE=salesforce-jwt) ---
# Appendix C alias in (parentheses).
SF_LOGIN_URL=                 # https://login.salesforce.com | https://test.salesforce.com
SF_CLIENT_ID=                 # Connected App / External Client App consumer key / JWT iss (App. C: SF_CONSUMER_KEY)
SF_INTEGRATION_USERNAME=      # dedicated integration user / JWT sub   (App. C: SF_INTEGRATION_USER)
SF_JWT_PRIVATE_KEY=           # secret · RSA private key — PEM contents directly (deployed hosts)
                               # OR a path to the key file (local dev only)         (App. C: SF_PRIVATE_KEY)
SF_API_VERSION=               # e.g. v67.0 (match the org: `sf org display` → Api Version)
SF_PUBSUB_ENDPOINT=           # api.pubsub.salesforce.com:7443

# --- Portal session / auth (BFF-native magic-link — ADR-0005, docs/ARCHITECTURE.md §3.2) -
SESSION_JWT_SECRET=           # secret · signing key for portal session tokens
SESSION_JWT_KID=              # active key id (supports rotation)
MAGIC_LINK_TTL_SECONDS=900
APP_BASE_URL=                 # https://portal.wholesaleshelfcorporations.com

# --- Magic-link email delivery ------------------------------------------------
# "console" (default) logs the link instead of sending it — zero setup for local dev.
# "smtp" sends via an existing mailbox (Google Workspace/M365/any SMTP) — no new paid
# vendor. EMAIL_PROVIDER_API_KEY below (SES/SendGrid/Postmark) is an alternative for
# later if volume grows; not required for the SMTP path.
EMAIL_SENDER=console          # console | smtp
SMTP_HOST=smtp.gmail.com      # Google Workspace; use smtp.office365.com for M365
SMTP_PORT=587
SMTP_USER=                    # sending mailbox, e.g. notifications@wholesaleshelfcorporations.com
SMTP_PASSWORD=                # secret · Google Workspace App Password (requires 2-Step Verification)
SMTP_FROM_EMAIL=              # usually same as SMTP_USER
SMTP_FROM_NAME=WSC Client Portal

# --- Stripe (payments) -------------------------------------------------------
STRIPE_SECRET_KEY=            # secret
STRIPE_WEBHOOK_SECRET=        # secret · verifies the Stripe-Signature header
STRIPE_PUBLISHABLE_KEY=       # client-safe (the ONLY key that may reach the SPA)

# --- Document storage: AWS S3 (choose AWS or Azure) --------------------------
AWS_REGION=
AWS_S3_BUCKET=
AWS_KMS_KEY_ID=               # SSE-KMS key for the document vault
AWS_ACCESS_KEY_ID=            # secret · prefer IAM role / OIDC over static keys
AWS_SECRET_ACCESS_KEY=        # secret
# --- Document storage: Azure Blob (alternative to AWS) -----------------------
# AZURE_STORAGE_ACCOUNT=
# AZURE_STORAGE_CONTAINER=
# AZURE_STORAGE_CONNECTION_STRING=   # secret · prefer Managed Identity

# --- E-signature: DocuSign (choose DocuSign or PandaDoc) ----------------------
DOCUSIGN_INTEGRATION_KEY=     # secret
DOCUSIGN_USER_ID=
DOCUSIGN_ACCOUNT_ID=
DOCUSIGN_PRIVATE_KEY=         # secret
DOCUSIGN_WEBHOOK_HMAC_KEY=    # secret
# --- E-signature: PandaDoc (alternative to DocuSign) -------------------------
# PANDADOC_API_KEY=           # secret
# PANDADOC_WEBHOOK_SECRET=    # secret

# --- Vercel edge staging gate (apps/web/middleware.ts) -----------------------
# Shared HTTP Basic Auth for the staging deploy only — set these in the Vercel
# project's own env vars (Production + Preview), not here. Remove the file and
# these once real public traffic is intended (ACTION-PLAN Grupo A #6).
BASIC_AUTH_USER=              # secret
BASIC_AUTH_PASSWORD=          # secret

# --- Infrastructure ----------------------------------------------------------
REDIS_URL=                    # cache · sessions · rate limits
QUEUE_URL=                    # SQS / Service Bus (async webhook + SF write-back)
DLQ_URL=                      # dead-letter queue
EMAIL_PROVIDER_API_KEY=       # secret · magic-link + notifications (SES/SendGrid/Postmark)
SENTRY_DSN=                   # error tracking (or equivalent)

# =============================================================================
# Alternative customer IdP — Auth0 / Cognito (ROADMAP Appendix C model)
# =============================================================================
# The roadmap assumes an external IdP for the customer magic-link, whereas
# docs/ARCHITECTURE.md §3.2 assumes the BFF issues the magic-link itself (the
# SESSION_JWT_* / MAGIC_LINK_TTL_SECONDS block above). Which model wins is an OPEN
# decision deferred to a Phase-1 ADR (see docs/adr/0001). If Auth0/Cognito is
# chosen, use these instead of the SESSION_JWT_* block:
# AUTH0_DOMAIN=
# AUTH0_AUDIENCE=
# AUTH0_CLIENT_ID=
